# Firebase (required — all app data stored in Firestore)
USE_FIREBASE=true
FIREBASE_CREDENTIALS=firebase-service-account.json
FIREBASE_PROJECT_ID=your-project-id

# Embeddings — local all-MiniLM-L6-v2 (no Hugging Face API key)
RAG_LOCAL_MODEL=sentence-transformers/all-MiniLM-L6-v2
ALLOW_HASHING_FALLBACK=false

# Human-like typing override (optional — dashboard "slow" profile is default)
WA_THINK_MIN=1.8
WA_THINK_MAX=3.8
WA_TYPE_DELAY_MIN=0.09
WA_TYPE_DELAY_MAX=0.24
WA_PUNCT_DELAY=0.55

# Optional
GEMINI_API_KEY=
RAG_TOP_K=4
RAG_MIN_SCORE=0.40
